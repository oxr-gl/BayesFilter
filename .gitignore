# LaTeX build byproducts
*.aux
*.bbl
*.bcf
*.blg
*.dvi
*.fdb_latexmk
*.fls
*.idx
*.ilg
*.ind
*.log
*.lof
*.lol
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*.xdv

# Generated PDF outputs; rebuild locally from the TeX sources.
/*.pdf
/docs/**/*.pdf

# Python build/test byproducts
__pycache__/
*.py[cod]
*.so
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated JSON outputs. Small promotion/verification benchmark artifacts under
# docs/benchmarks are intentionally tracked when committed with their Markdown
# summaries and plan/result notes.
*.json
!docs/benchmarks/*.json
!docs/benchmarks/**/*.json
!docs/plans/artifacts/lgssm-first-neutra-gpu-training-2026-07-07/lgssm_static_qr_exact_kalman_affine_neutra_gpu_xla_training_state_seed20260707.json

# Local diagnostic sidecars from benchmark/tuning runs. Public JSON/Markdown
# summaries under docs/benchmarks stay trackable when they support evidence.
docs/benchmarks/**/*_public_artifacts_*/private_diagnostics/
docs/benchmarks/**/private_diagnostics/*.npz
docs/benchmarks/**/private_diagnostics/*.npy

# OS metadata from local/vendored snapshots
.DS_Store
Icon?
desktop.ini

# Local editor/tool state
.codex/
.codex_*_write_probe
.serena/
.cache/
.claude/
.claude_reviews/
.localenv/

# Agent scratch rewrite buffers. Evidence notes/results under docs/plans stay
# tracked when they support a claim, gate, or promotion decision.
.tmp_*_rewrite.tex

# Nested third-party source snapshots should be tracked as files, not embedded
# repositories.
third_party/**/.git/
.localsource/**/.git/

# Local literature workspace and downloaded papers.
.research/
local_research/
.localsource/
